void Load(ifstream &fp) {
    string str;
    if (!fp.is_open()) return;
    int row = 0;
    programLoaded = false;
    
    while (getline(fp, str)) {
        if (str.substr(0, 4) == "$AMJ") {
            INIT();
            row = 0;
            
            while (getline(fp, str)) {
                if (str.substr(0, 4) == "$DTA") {
                    if (getline(fp, currentDataLine)) {
                        dataAvailable = true;
                    }
                    break;
                }
                
                for (int i = 0; i < 40; i++) {
                    buffer[i] = ' ';
                }
                
                int len = str.length();
                for (int i = 0; i < len; i++) {
                    buffer[i] = str[i];
                }
                
                for (int i = 0; i < 40; i += 4) {
                    for (int k = 0; k < 4; k++) {
                        M[row][k] = buffer[i + k];
                    }
                    row++;
                    if (row >= 200) break;  // Changed to 200
                }

                if (row >= 200) break;  // Changed to 200
            }
            
            while (getline(fp, str)) {
                if (str.substr(0, 4) == "$END") {
                    programLoaded = true;
                    break;
                }
            }
            
            if (programLoaded) break;
        }
    }
}

void INIT() {
    for (int i = 0; i < 200; i++) {  // Changed to 200
        for (int j = 0; j < 4; j++) {
            M[i][j] = ' ';
        }
    }
    for (int i = 0; i < 4; i++) {
        IR[i] = ' ';
        R[i] = ' ';
    }
    IC = 0;
    SI = 0;
    C = 0;
    dataAvailable = false;
}



void print_memory_block() {
    cout << "Memory Contents:" << endl;
    for (int i = 0; i < 200; i++) {  // Changed to 200
        cout << "M[" << i << "]: ";
        for (int j = 0; j < 4; j++) {
            cout << M[i][j];
        }
        cout << endl;
    }
}

void START_EXECUTION() {
    IC = 0;
    EXECUTE_USER_PROGRAM();
}

void EXECUTE_USER_PROGRAM() {
    while (1) {
        for (int i = 0; i < 4; i++) {
            IR[i] = M[IC][i];
        }
        
        if (IR[0] == ' ' || (IR[0] == ' ' && IR[1] == ' ')) {
            break;
        }
        
        IC++;
        
        if (IR[0] == 'G' && IR[1] == 'D') {
            SI = 1;
            MOS();
        }
        else if (IR[0] == 'P' && IR[1] == 'D') {
            SI = 2;
            MOS();
        }
        else if (IR[0] == 'H') {
            SI = 3;
            MOS();
            break;
        }
        else if (IR[0] == 'L' && IR[1] == 'R') {
            LR();
        }
        else if (IR[0] == 'S' && IR[1] == 'R') {
            SR();
        }
        else if (IR[0] == 'B' && IR[1] == 'T') {
            BT();
        }
        else if (IR[0] == 'C' && IR[1] == 'R') {
            CR();
        }
        else if (IR[0] == 'A' && IR[1] == 'D') {  // New Addition instruction
            AD();
        }
        else {
            break;
        }
    }
}

void LR() {
    string operand = string(1, IR[2]) + string(1, IR[3]);
    int address = stoi(operand);
    
    for(int i = 0; i < 4; i++) {
        R[i] = M[address][i]; 
    }
}

void SR() {
    string operand = string(1, IR[2]) + string(1, IR[3]);
    int address = stoi(operand);
    
    for(int i = 0; i < 4; i++) {
        M[address][i] = R[i]; 
    }
}

void CR() {
    string operand = string(1, IR[2]) + string(1, IR[3]);
    int address = stoi(operand);
    
    C = 1;
    for(int i = 0; i < 4; i++) {
        if(R[i] != M[address][i]) {
            C = 0;
            break; 
        }
    }
}

void BT() {
    if(C == 1) {
        int address =stoi(string(1, IR[2]) + string(1, IR[3]));
        IC = address;
        C = 0; 
    }
}

// New Addition Instruction
